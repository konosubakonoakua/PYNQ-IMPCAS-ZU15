From 0d27e7f38be83abee8ad7376d91a2f54ce2a58c8 Mon Sep 17 00:00:00 2001
From: "rafael.ren" <rafael.ren@foxmail.com>
Date: Sat, 25 Apr 2026 15:43:39 +0800
Subject: [PATCH 1/3] Enable-CCI-debug-NIDEN-and-SPINDEN-on-CCI400

---
 lib/sw_apps/zynqmp_fsbl/src/xfsbl_hooks.c | 67 ++++++++++++++++++++++-
 1 file changed, 64 insertions(+), 3 deletions(-)

diff --git a/lib/sw_apps/zynqmp_fsbl/src/xfsbl_hooks.c b/lib/sw_apps/zynqmp_fsbl/src/xfsbl_hooks.c
index 6be980ca38..7e35e114fc 100644
--- a/lib/sw_apps/zynqmp_fsbl/src/xfsbl_hooks.c
+++ b/lib/sw_apps/zynqmp_fsbl/src/xfsbl_hooks.c
@@ -71,13 +71,74 @@ u32 XFsbl_HookAfterBSDownload(void )
 }
 #endif
 
+
+static void print_el(void) {
+	register uint64_t x0 __asm__ ("x0");
+	__asm__ ("mrs x0, CurrentEL;" : : : "%x0");
+	XFsbl_Printf(DEBUG_PRINT_ALWAYS, "EL = %x\r\n", x0 >> 2);
+}
+
+
+static void cci_reg_dump(void) {
+	// offsets from UG1087
+	uint64_t offsets[] = {0, 0x10, 0x14, 0x18, 0x1c, 0x40};
+
+	XFsbl_Printf(DEBUG_PRINT_ALWAYS, "CCI_REG: register dump\r\n");
+
+	for (int i = 0; i < sizeof(offsets)/sizeof(*offsets); i++) {
+		uint64_t offs = offsets[i];
+		u32 val = XFsbl_In32(XPAR_PSU_CCI_REG_S_AXI_BASEADDR + offs);
+		XFsbl_Printf(DEBUG_PRINT_ALWAYS, "  offset %x = %x\r\n", offs, val);
+	}
+}
+
+
+static void cci_reg_debug_enable(void) {
+	const uint64_t OFFS_CCI_MISC_CTRL = 0x40;
+
+	const uint32_t CCI_MISC_CTRL_NIDEN_MASK = 0x2;
+	const uint32_t CCI_MISC_CTRL_SPIDEN_MASK = 0x1;
+
+	XFsbl_Printf(DEBUG_PRINT_ALWAYS, "CCI_REG: debug enable\r\n");
+
+	XFsbl_Out32(
+		XPAR_PSU_CCI_REG_S_AXI_BASEADDR + OFFS_CCI_MISC_CTRL,
+		CCI_MISC_CTRL_NIDEN_MASK | CCI_MISC_CTRL_SPIDEN_MASK
+	);
+}
+
+
+static void cci_gpv_dump(void) {
+  // Key offsets in the CCI GPV region for Slave Interface control registers
+  // These include Snoop Control and Shareable Override registers for S0, S3.
+	// Refer to ZynqMP UG1085 and ARM CCI-400 TRM for exact definitions.
+  uint64_t offsets[] = {
+      0x1000, // S0 Snoop Control Register
+      0x1004, // S0 Shareable Override Register
+      0x4000, // S3 Snoop Control Register
+  };
+
+	XFsbl_Printf(DEBUG_PRINT_ALWAYS, "CCI_GPV: key register dump");
+
+	for (int i = 0; i < sizeof(offsets)/sizeof(*offsets); i++) {
+    uint64_t offs = offsets[i];
+    u32 val = XFsbl_In32(XPAR_PSU_CCI_GPV_S_AXI_BASEADDR + offs);
+    XFsbl_Printf(DEBUG_PRINT_ALWAYS, "  relative offset 0x%llx = 0x%x ", offs, val);
+	}
+}
+
+
 u32 XFsbl_HookBeforeHandoff(u32 EarlyHandoff)
 {
 	u32 Status = XFSBL_SUCCESS;
 
-	/**
-	 * Add the code here
-	 */
+	print_el();
+
+	cci_reg_dump();
+	cci_reg_debug_enable();
+	cci_reg_dump();
+
+	cci_gpv_dump();
 
 	return Status;
 }
